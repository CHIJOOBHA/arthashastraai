{
  "entities": {
    "IntelligenceItem": {
      "title": "Intelligence Item",
      "description": "A piece of data gathered from external sources.",
      "type": "object",
      "properties": {
        "source": { "type": "string", "description": "The origin of the data (e.g., 'web', 'database', 'darkweb')." },
        "content": { "type": "string", "description": "The raw or processed content of the intelligence." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the data was collected." },
        "metadata": { "type": "object", "description": "Additional source-specific information." }
      },
      "required": ["source", "content", "timestamp"]
    },
    "Tweet": {
      "title": "Monitored Tweet",
      "description": "A tweet collected from a high-value account.",
      "type": "object",
      "properties": {
        "tweetId": { "type": "string", "description": "The unique ID of the tweet on Twitter." },
        "author": { "type": "string", "description": "The Twitter handle of the author." },
        "text": { "type": "string", "description": "The content of the tweet." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the tweet was posted." },
        "processed": { "type": "boolean", "description": "Whether a response has been generated for this tweet." }
      },
      "required": ["tweetId", "author", "text", "timestamp"]
    },
    "AgentResponse": {
      "title": "Agent Response",
      "description": "A response generated by the AI for a specific tweet or intelligence item.",
      "type": "object",
      "properties": {
        "targetId": { "type": "string", "description": "The ID of the tweet or intelligence item being responded to." },
        "responseText": { "type": "string", "description": "The AI-generated response." },
        "status": { "type": "string", "enum": ["pending", "posted", "failed"], "description": "The status of the response posting." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the response was generated." }
      },
      "required": ["targetId", "responseText", "status", "timestamp"]
    },
    "AgentLog": {
      "title": "Agent Log",
      "description": "A log entry for agent operations.",
      "type": "object",
      "properties": {
        "agentName": { "type": "string", "description": "The name of the agent (e.g., 'Collector', 'TwitterMonitor')." },
        "action": { "type": "string", "description": "The action performed." },
        "status": { "type": "string", "description": "The result of the action." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the log was created." }
      },
      "required": ["agentName", "action", "status", "timestamp"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat block linking a user to their messages.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title"]
    },
    "Message": {
      "title": "Message",
      "description": "A single chat message within a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "hash": { "type": "string" },
        "previousHash": { "type": "string" },
        "index": { "type": "number" }
      },
      "required": ["id", "role", "text", "userId"]
    }
  },
  "firestore": {
    "/intelligence/{id}": { "schema": "IntelligenceItem", "description": "Collection of gathered intelligence." },
    "/tweets/{id}": { "schema": "Tweet", "description": "Collection of monitored tweets." },
    "/responses/{id}": { "schema": "AgentResponse", "description": "Collection of AI-generated responses." },
    "/agent_logs/{id}": { "schema": "AgentLog", "description": "Logs of agent activities." },
    "/users/{uid}": { "schema": "User", "description": "User profiles and roles." },
    "/conversations/{id}": { "schema": "Conversation", "description": "Private chat block per user." },
    "/conversations/{id}/messages/{messageId}": { "schema": "Message", "description": "Ledger entries of the chat." }
  }
}
