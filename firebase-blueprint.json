{
  "entities": {
    "IntelligenceItem": {
      "title": "Intelligence Item",
      "description": "A piece of data gathered and analyzed by the Central Brain.",
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "content": { "type": "string" },
        "explanationId": { "type": "string", "description": "Link to the detailed breakdown." },
        "isBroadcasted": { "type": "boolean", "description": "Flag for the Twitter execution pipe." },
        "metadata": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["source", "content", "timestamp", "isBroadcasted"]
    },
    "Tweet": {
      "title": "Monitored Tweet",
      "description": "A tweet collected from a high-value account.",
      "type": "object",
      "properties": {
        "tweetId": { "type": "string", "description": "The unique ID of the tweet on Twitter." },
        "author": { "type": "string", "description": "The Twitter handle of the author." },
        "text": { "type": "string", "description": "The content of the tweet." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the tweet was posted." },
        "processed": { "type": "boolean", "description": "Whether a response has been generated for this tweet." }
      },
      "required": ["tweetId", "author", "text", "timestamp"]
    },
    "AgentResponse": {
      "title": "Agent Response",
      "description": "A response generated by the AI for a specific tweet or intelligence item.",
      "type": "object",
      "properties": {
        "targetId": { "type": "string", "description": "The ID of the tweet or intelligence item being responded to." },
        "responseText": { "type": "string", "description": "The AI-generated response." },
        "status": { "type": "string", "enum": ["pending", "posted", "failed"], "description": "The status of the response posting." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the response was generated." }
      },
      "required": ["targetId", "responseText", "status", "timestamp"]
    },
    "AgentLog": {
      "title": "Agent Log",
      "description": "A log entry for agent operations.",
      "type": "object",
      "properties": {
        "agentName": { "type": "string", "description": "The name of the agent (e.g., 'Collector', 'TwitterMonitor')." },
        "action": { "type": "string", "description": "The action performed." },
        "status": { "type": "string", "description": "The result of the action." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the log was created." }
      },
      "required": ["agentName", "action", "status", "timestamp"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "explanationViewCount": { "type": "number", "description": "Number of free explanations viewed." },
        "isSubscribed": { "type": "boolean", "description": "Whether the user has an active subscription." }
      },
      "required": ["uid", "email", "role"]
    },
    "Explanation": {
      "title": "Explanation",
      "description": "A detailed economic explanation linked from a tweet.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string", "description": "The detailed economic analysis." },
        "targetTweetId": { "type": "string", "description": "The ID of the tweet this explains." },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "content", "targetTweetId", "timestamp"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription details.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired", "cancelled"] },
        "razorpaySubscriptionId": { "type": "string" },
        "plan": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment transaction record.",
      "type": "object",
      "properties": {
        "paymentId": { "type": "string" },
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "blockchainTxId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["paymentId", "userId", "amount", "status"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat block linking a user to their messages.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title"]
    },
    "Message": {
      "title": "Aitihya Witness Entry",
      "description": "An immutable witness entry on the Aitihya Chain.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "hash": { "type": "string", "description": "SHA-256 integrity hash." },
        "previousHash": { "type": "string", "description": "Link to the previous witness block." },
        "index": { "type": "number" },
        "agentId": { "type": "string" }
      },
      "required": ["id", "role", "text", "userId", "hash", "index"]
    }
  },
  "firestore": {
    "/intelligence/{id}": { "schema": "IntelligenceItem", "description": "Collection of gathered intelligence." },
    "/tweets/{id}": { "schema": "Tweet", "description": "Collection of monitored tweets." },
    "/responses/{id}": { "schema": "AgentResponse", "description": "Collection of AI-generated responses." },
    "/agent_logs/{id}": { "schema": "AgentLog", "description": "Logs of agent activities." },
    "/users/{uid}": { "schema": "User", "description": "User profiles and roles." },
    "/explanations/{id}": { "schema": "Explanation", "description": "Detailed economic explanations for tweets." },
    "/subscriptions/{uid}": { "schema": "Subscription", "description": "User subscription records." },
    "/payments/{id}": { "schema": "Payment", "description": "Transaction logs." },
    "/conversations/{id}": { "schema": "Conversation", "description": "Private chat block per user." },
    "/conversations/{id}/messages/{messageId}": { "schema": "Message", "description": "Ledger entries of the chat." }
  }
}
