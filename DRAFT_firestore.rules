rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // DEFAULT DENY CATCH-ALL
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // GLOBAL HELPERS
    // ==========================================
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    
    // AD-HOC ADMINS: Hardcoded for bootstrap, but usually checked via /admins/ collection
    function isAdmin() { 
      return isSignedIn() && isVerified() && (
        request.auth.token.email == "jhansidharmana222@gmail.com" || 
        request.auth.token.email == "chitti.bhargav3@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // ==========================================
    // ENTITY VALIDATORS
    // ==========================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() <= 64 &&
             data.email is string && data.email.size() <= 128 &&
             data.role in ['admin', 'user'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'role', 'text', 'userId']) &&
             data.id is string && data.id.size() <= 128 &&
             data.role in ['user', 'model'] &&
             data.text is string && data.text.size() <= 5000 &&
             data.userId == request.auth.uid;
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['id', 'userId', 'title']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200;
    }

    // ==========================================
    // COLLECTION RULES
    // ==========================================

    // PUBLIC READ-ONLY
    match /intelligence/{id} {
      allow get: if isValidId(id);
      allow list: if true;
      allow write: if false; // System only
    }

    match /explanations/{id} {
      allow get: if isValidId(id);
      allow list: if true;
      allow write: if false; // System only
    }

    // ADMIN ONLY (AUDIT LOGS)
    match /agent_logs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /tweets/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /responses/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /payments/{id} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Only via backend
    }

    // USER PROFILES
    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      
      // Strict update: users cannot change their own roles
      allow update: if (isOwner(uid) && 
                      isValidUser(incoming()) && 
                      incoming().role == existing().role &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['explanationViewCount'])) ||
                    isAdmin();
      
      allow create: if isOwner(uid) && 
                      isValidUser(incoming()) && 
                      incoming().role == 'user'; // Default to user
    }

    match /subscriptions/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin(); // Only backend
    }

    // CHAT SECTORS (THE WITNESS LEDGER)
    match /conversations/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidConversation(incoming()) && isValidId(id);
      allow update: if isSignedIn() && isOwner(existing().userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['lastMessageAt', 'updatedAt', 'title']);
      allow delete: if false;

      match /messages/{messageId} {
        // Master Gate: Check parent conversation ownership
        function parentOwned() {
          return get(/databases/$(database)/documents/conversations/$(id)).data.userId == request.auth.uid;
        }

        allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && isValidMessage(incoming()) && parentOwned() && isValidId(messageId);
        allow update, delete: if false; // Immutable Chain
      }
    }
  }
}
